UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end

    local inputType = input.UserInputType
    local keyCode  = input.KeyCode

    local isPullInput = (inputType == Enum.UserInputType.MouseButton1)
        or (inputType == Enum.UserInputType.Gamepad1 and keyCode == Enum.KeyCode.ButtonR2)

    if isPullInput and smoothPullEnabled then
        isSmoothPulling = true
        spawn(function()
            while isSmoothPulling and smoothPullEnabled do
                smoothTeleportToBall()
                wait(0.01)
            end
        end)
    end

    if jpEnabled then
        local isJPArm = (inputType == Enum.UserInputType.Keyboard and keyCode == Enum.KeyCode.R)
            or (inputType == Enum.UserInputType.Gamepad1 and keyCode == Enum.KeyCode.ButtonR1)

        if isJPArm and not boostArmed then
            boostArmed = true
            startDisarmTimer()
        end
    end

    local isStickyToggle = (inputType == Enum.UserInputType.Keyboard and keyCode == Enum.KeyCode.F)
        or (keyCode == Enum.KeyCode.DPadRight)

    if isStickyToggle then
        stickyEnabled = not stickyEnabled
        stickySetState(stickyEnabled)
        if not stickyEnabled and jumpConnection then
            jumpConnection:Disconnect()
            jumpConnection = nil
        end
    end

    if keyCode == Enum.KeyCode.RightShift then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

UserInputService.InputEnded:Connect(function(input)
    local inputType = input.UserInputType
    local keyCode  = input.KeyCode

    local isPullRelease = (inputType == Enum.UserInputType.MouseButton1)
        or (inputType == Enum.UserInputType.Gamepad1 and keyCode == Enum.KeyCode.ButtonR2)

    if isPullRelease then
        isSmoothPulling = false
    end
end)
