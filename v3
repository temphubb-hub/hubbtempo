-- Helper: search a Hitboxes folder for this player's parts
local function searchHitboxFolder(hitboxesFolder, myName, myUserId, found)
    if not hitboxesFolder then return end
    for _, folder in ipairs(hitboxesFolder:GetChildren()) do
        if folder.Name == myName or folder.Name == myUserId then
            for _, part in ipairs(folder:GetDescendants()) do
                if part:IsA("BasePart") then table.insert(found, part) end
            end
            if folder:IsA("BasePart") then table.insert(found, folder) end
        end
    end
    for _, part in ipairs(hitboxesFolder:GetChildren()) do
        if part:IsA("BasePart") and
           (part.Name == myName or part.Name == myUserId) then
            table.insert(found, part)
        end
    end
end

local function getMyHitboxParts()
    local found = {}
    local myName   = LocalPlayer.Name
    local myUserId = tostring(LocalPlayer.UserId)

    local gamesFolder = Workspace:FindFirstChild("Games")
    if gamesFolder then
        for _, gameInstance in ipairs(gamesFolder:GetChildren()) do
            local rep = gameInstance:FindFirstChild("Replicated")
            if rep then
                searchHitboxFolder(rep:FindFirstChild("Hitboxes"), myName, myUserId, found)
            end
        end
    end

    local miniGames = Workspace:FindFirstChild("MiniGames")
    if miniGames then
        for _, gameInstance in ipairs(miniGames:GetChildren()) do
            local rep = gameInstance:FindFirstChild("Replicated")
            if rep then
                searchHitboxFolder(rep:FindFirstChild("Hitboxes"), myName, myUserId, found)
            end
        end
    end

    local parkMap = Workspace:FindFirstChild("ParkMap")
    if parkMap then
        for _, child in ipairs(parkMap:GetChildren()) do
            local rep = child:FindFirstChild("Replicated")
            if rep then
                searchHitboxFolder(rep:FindFirstChild("Hitboxes"), myName, myUserId, found)
            end
        end
    end

    return found
end

local function getMyCatchbox()
    local myName   = LocalPlayer.Name
    local myUserId = tostring(LocalPlayer.UserId)

    local function searchForCatchbox(root)
        if not root then return nil end
        for _, desc in ipairs(root:GetDescendants()) do
            if desc:IsA("BasePart") and desc.Name == "CatchBox" then
                local ancestor = desc.Parent
                while ancestor do
                    if ancestor.Name == myName or ancestor.Name == myUserId then
                        return desc
                    end
                    ancestor = ancestor.Parent
                end
            end
        end
        return nil
    end

