-- CFrame offset so the item sits in a sensible position on the body part
local CAT_OFFSET = {
    Hats    = CFrame.new(0,  0.6,  0),
    Hair    = CFrame.new(0,  0.4,  0),
    Face    = CFrame.new(0,  0,    0.5),
