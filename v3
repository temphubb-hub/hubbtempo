local function applyTR()
    local parts = getMyHitboxParts()
    for _, part in ipairs(parts) do
        if not trOriginals[part] then
            trOriginals[part] = {
                Size         = part.Size,
                Transparency = part.Transparency,
            }
        end
        part.Size         = Vector3.new(trSize, trSize, trSize)
        part.Transparency = trTransparency
    end
    local cb = getMyCatchbox()
    if cb then
        if not trOriginals[cb] then
            trOriginals[cb] = {
                Size         = cb.Size,
                Transparency = cb.Transparency,
            }
        end
        cb.Size         = Vector3.new(trCatchboxSize, trCatchboxSize, trCatchboxSize)
        cb.Transparency = trTransparency
    end
end

local function resetTR()
    for part, orig in pairs(trOriginals) do
        if part and part.Parent then
            part.Size         = orig.Size
            part.Transparency = orig.Transparency
        end
    end
    trOriginals = {}
end

RunService.Heartbeat:Connect(function()
    if trEnabled then
        applyTR()
    end
end)

LocalPlayer.CharacterAdded:Connect(function()
    trOriginals = {}
    if trEnabled then
        task.wait(1.5)
        applyTR()
    end
end)


