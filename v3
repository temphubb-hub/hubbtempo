-- Play an emote — uses game:GetObjects() which works client-side.
-- Loads the bundle, finds the Animation inside, caches the real ID.
local emoteCache = {}

local function playEmote(assetId)
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then return end

    local animId = emoteCache[assetId]
    if not animId then
        local ok, objects = pcall(function()
            return game:GetObjects("rbxassetid://" .. assetId)
        end)
        if not ok or not objects then return end
        for _, obj in ipairs(objects) do
            if obj:IsA("Animation") and obj.AnimationId ~= "" then
                animId = obj.AnimationId
                break
            end
            -- also check descendants in case it's wrapped in a model
            for _, desc in ipairs(obj:GetDescendants()) do
                if desc:IsA("Animation") and desc.AnimationId ~= "" then
                    animId = desc.AnimationId
                    break
                end
            end
            if animId then break end
        end
        if not animId then return end
        emoteCache[assetId] = animId
    end

    local anim = Instance.new("Animation")
    anim.AnimationId = animId
    local ok2, track = pcall(function()
        return animator:LoadAnimation(anim)
    end)
    if ok2 and track then track:Play() end
end

