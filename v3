-- Weld an accessory Handle to a character body part with a Motor6D
local function weldAccToChar(handle, bodyPart, offsetCF)
    -- Remove any existing welds inside handle that might fight us
    for _, w in ipairs(handle:GetChildren()) do
        if w:IsA("Weld") or w:IsA("Motor6D") or w:IsA("WeldConstraint") then
            w:Destroy()
        end
    end
    handle.Massless  = true
    handle.CanCollide = false
    handle.Anchored  = false

    local motor = Instance.new("Motor6D")
    motor.Name   = "AccessoryWeld"
    motor.Part0  = bodyPart
    motor.Part1  = handle
    motor.C0     = offsetCF or CFrame.new()
    motor.C1     = CFrame.new()
    motor.Parent = handle
end

-- Add an accessory to local character only — manually welded to the right body part
local function addAccessory(assetId, category)
    local char = LocalPlayer.Character
    if not char then return end

    -- Remove previous instance of same asset if already added
    if addedAccessories[assetId] then
        pcall(function() addedAccessories[assetId]:Destroy() end)
        addedAccessories[assetId] = nil
    end

    local ok, objects = pcall(function()
        return game:GetObjects("rbxassetid://" .. assetId)
    end)
    if not ok or not objects then return end

    for _, obj in ipairs(objects) do
        local acc = nil
        if obj:IsA("Accessory") or obj:IsA("Hat") then
            acc = obj
        else
            acc = obj:FindFirstChildOfClass("Accessory")
                or obj:FindFirstChildOfClass("Hat")
        end
        if acc then
            local handle = acc:FindFirstChild("Handle")
            if handle then
                -- Determine which body part and offset to use
                local targetPartName = CAT_WELD_TARGET[category] or "UpperTorso"
                local offset         = CAT_OFFSET[category] or CFrame.new()
                local bodyPart       = char:FindFirstChild(targetPartName)
                    or char:FindFirstChild("HumanoidRootPart")

                -- Try Humanoid:AddAccessory first — works if attachments match
                local addOk = pcall(function()
                    acc.Parent = Workspace
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then hum:AddAccessory(acc) end
                end)

                -- If accessory didn't weld properly (still no weld/motor), force-weld it
                local hasWeld = false
                for _, w in ipairs(handle:GetChildren()) do
                    if w:IsA("Weld") or w:IsA("Motor6D") or w:IsA("WeldConstraint") then
                        hasWeld = true
                        break
                    end
                end

                if not hasWeld and bodyPart then
                    acc.Parent = char
                    weldAccToChar(handle, bodyPart, offset)
                end

                addedAccessories[assetId] = acc
            else
                -- No Handle — just parent directly
                acc.Parent = char
                addedAccessories[assetId] = acc
            end
            break
        end
    end
end

local function removeAccessory(assetId)
    if addedAccessories[assetId] then
        pcall(function() addedAccessories[assetId]:Destroy() end)
        addedAccessories[assetId] = nil
    end
end

local function removeAllAccessories()
    for id in pairs(addedAccessories) do
        removeAccessory(id)
    end
end

