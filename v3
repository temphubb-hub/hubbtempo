    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(0, 55, 0, 20)
    valLbl.Position = UDim2.new(1, -62, 0, 8)
    valLbl.BackgroundTransparency = 1
    valLbl.TextColor3 = R
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 12
    valLbl.TextXAlignment = Enum.TextXAlignment.Right
    valLbl.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -28, 0, 4)
    track.Position = UDim2.new(0, 14, 0, 38)
    track.BackgroundColor3 = Color3.fromRGB(35, 15, 15)
    track.BorderSizePixel = 0
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = R
    fill.BorderSizePixel = 0
    fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.BackgroundColor3 = WH
    knob.BorderSizePixel = 0
    knob.Parent = track
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local glow = Instance.new("Frame")
    glow.Size = UDim2.new(0, 6, 0, 6)
    glow.AnchorPoint = Vector2.new(0.5, 0.5)
    glow.Position = UDim2.new(0.5, 0, 0.5, 0)
    glow.BackgroundColor3 = R
    glow.BorderSizePixel = 0
    glow.Parent = knob
    Instance.new("UICorner", glow).CornerRadius = UDim.new(1, 0)

    local function applyPct(pct)
        local raw   = min + pct * (max - min)
        local steps = math.floor((raw - min) / increment + 0.5)
        local val   = math.clamp(min + steps * increment, min, max)
        local decimals = 0
        local dot = tostring(increment):find("%.")
        if dot then decimals = #tostring(increment) - dot end
        local mult = 10 ^ decimals
        val = math.floor(val * mult + 0.5) / mult
        local p = (val - min) / (max - min)
        fill.Size     = UDim2.new(p, 0, 1, 0)
        knob.Position = UDim2.new(p, 0, 0.5, 0)
        valLbl.Text   = tostring(val)
        callback(val)
    end
    applyPct((default - min) / (max - min))

    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(1, 0, 1, 0)
    sliderBtn.BackgroundTransparency = 1
    sliderBtn.Text = ""
    sliderBtn.Parent = track
    sliderBtn.MouseButton1Down:Connect(function()
        activeDrag = { track = track, updateFn = applyPct }
        local tw = track.AbsoluteSize.X
        if tw == 0 then return end
        applyPct(math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / tw, 0, 1))
    end)
    return row
end

