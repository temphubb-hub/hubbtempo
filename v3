local activeDrag = nil  -- { track, updateFn } or nil

UserInputService.InputChanged:Connect(function(input)
    if not activeDrag then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    local trackPos   = activeDrag.track.AbsolutePosition.X
    local trackWidth = activeDrag.track.AbsoluteSize.X
    if trackWidth == 0 then return end
    local pct = math.clamp((input.Position.X - trackPos) / trackWidth, 0, 1)
    activeDrag.updateFn(pct)
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        activeDrag = nil
    end
end)

local function createSlider(parent, labelText, min, max, default, increment, callback)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0.92, 0, 0, 60)
    row.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    row.BorderSizePixel = 0
    row.Parent = parent

    local rowCorner = Instance.new("UICorner")
    rowCorner.CornerRadius = UDim.new(0, 8)
    rowCorner.Parent = row

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 0, 20)
    label.Position = UDim2.new(0, 14, 0, 8)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 50, 0, 20)
    valueLabel.Position = UDim2.new(1, -60, 0, 8)
    valueLabel.BackgroundTransparency = 1
    valueLabel.TextColor3 = Color3.fromRGB(108, 92, 231)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 13
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -28, 0, 6)
    track.Position = UDim2.new(0, 14, 0, 38)
    track.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    track.BorderSizePixel = 0
    track.Parent = row

    local trackCorner = Instance.new("UICorner")
    trackCorner.CornerRadius = UDim.new(1, 0)
    trackCorner.Parent = track

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(108, 92, 231)
    fill.BorderSizePixel = 0
    fill.Parent = track

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fill

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = track

    local knobCorner = Instance.new("UICorner")
    knobCorner.CornerRadius = UDim.new(1, 0)
    knobCorner.Parent = knob

    -- Takes a 0-1 percentage and snaps to increment
    local function applyPct(pct)
        local raw   = min + pct * (max - min)
        local steps = math.floor((raw - min) / increment + 0.5)
        local val   = math.clamp(min + steps * increment, min, max)
        -- round to avoid floating point display noise
        local decimals = 0
        local dot = tostring(increment):find("%.")
        if dot then decimals = #tostring(increment) - dot end
        local mult = 10 ^ decimals
        val = math.floor(val * mult + 0.5) / mult
        local p = (val - min) / (max - min)
        fill.Size          = UDim2.new(p, 0, 1, 0)
        knob.Position      = UDim2.new(p, 0, 0.5, 0)
        valueLabel.Text    = tostring(val)
        callback(val)
    end

    -- Set initial value
    applyPct((default - min) / (max - min))

    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(1, 0, 1, 0)
    sliderBtn.BackgroundTransparency = 1
    sliderBtn.Text = ""
    sliderBtn.Parent = track

    sliderBtn.MouseButton1Down:Connect(function()
        -- Register THIS slider as the active drag target
        activeDrag = { track = track, updateFn = applyPct }
        -- Also apply immediately at click position
        local trackPos   = track.AbsolutePosition.X
        local trackWidth = track.AbsoluteSize.X
        if trackWidth == 0 then return end
        local pct = math.clamp((UserInputService:GetMouseLocation().X - trackPos) / trackWidth, 0, 1)
        applyPct(pct)
    end)

    return row
end

