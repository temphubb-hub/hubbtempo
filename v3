local function startDisarmTimer()
    if armTimeout then task.cancel(armTimeout) end
    armTimeout = task.delay(2, function()
        boostArmed = false
    end)
end

local function setupJPTouch(char)
    local rootPart = char:WaitForChild("HumanoidRootPart", 10)
    if not rootPart then return end
    if jpTouchConnection then jpTouchConnection:Disconnect() end
    jpTouchConnection = rootPart.Touched:Connect(function(otherPart)
        if not jpEnabled then return end
        if not boostArmed then return end
        local otherCharacter = otherPart.Parent
        local otherPlayer = Players:GetPlayerFromCharacter(otherCharacter)
        if otherPlayer and otherPlayer ~= LocalPlayer then
            local head = otherCharacter:FindFirstChild("Head")
            if head and head.CanCollide then
                local lastBoostTime = lastBoostTimes[otherPlayer] or 0
                if tick() - lastBoostTime >= boostCooldown then
                    boostArmed = false
                    if armTimeout then task.cancel(armTimeout) end
                    local hum = char:FindFirstChild("Humanoid")
                    local moveDir = hum and hum.MoveDirection or Vector3.new()
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(moveDir.X * 5, boostPower, moveDir.Z * 5)
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bv.Parent = rootPart
                    task.wait(0.1)
                    bv:Destroy()
                    lastBoostTimes[otherPlayer] = tick()
                    active = false
                    task.wait(2)
                    active = true
                end
            end
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    if jpEnabled then setupJPTouch(char) end
end)

