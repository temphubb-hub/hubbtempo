-- STICKY HEAD LOGIC
--------------------------------------------------------
local function closestPlayer()
    local nearest
    local dist = 35
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local pHrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if pHrp and hum and hum.Health > 0 then
                local d = (pHrp.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    nearest = p
                end
            end
        end
    end
    return nearest
end

local function connectJump(target)
    if jumpConnection then jumpConnection:Disconnect() end
    local hum = target.Character:FindFirstChild("Humanoid")
    local head = target.Character:FindFirstChild("Head")
    if not hum or not head then return end
    jumpConnection = hum.Jumping:Connect(function()
        if not stickyEnabled then return end
        if humanoid.FloorMaterial ~= Enum.Material.Air then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        local headPos = head.Position + Vector3.new(0, 2.2, 0)
        local offset = headPos - hrp.Position
        hrp.AssemblyLinearVelocity += Vector3.new(
            offset.Unit.X * (pullStrength * 40),
            12,
            offset.Unit.Z * (pullStrength * 40)
        )
    end)
end

RunService.RenderStepped:Connect(function()
    if not stickyEnabled then return end
    local target = closestPlayer()
    if not target or not target.Character then return end
    connectJump(target)
    local head = target.Character:FindFirstChild("Head")
    if not head then return end
    local headPos = head.Position + Vector3.new(0, 1.6, 0)
    local offset = headPos - hrp.Position
    local dist = offset.Magnitude
    local vel = hrp.AssemblyLinearVelocity
    if dist > 2.5 then
        local desired = offset.Unit * (pullStrength * 14)
        hrp.AssemblyLinearVelocity = Vector3.new(
            vel.X + (desired.X - vel.X) * 0.2,
            vel.Y,
            vel.Z + (desired.Z - vel.Z) * 0.2
        )
    end
    if dist <= 3 then
        local centerDir = (headPos - hrp.Position)
        local horizontal = Vector3.new(centerDir.X, 0, centerDir.Z)
        hrp.AssemblyLinearVelocity += horizontal.Unit * (stickiness * 5)
    end
    if dist <= 2 then
        local boostOffset = headPos - hrp.Position
        hrp.AssemblyLinearVelocity = Vector3.new(
            boostOffset.X * (stickiness * 5),
            hrp.AssemblyLinearVelocity.Y,
            boostOffset.Z * (stickiness * 5)
        )
    end
    if dist <= 1.2 then
        local lock = headPos - hrp.Position
        hrp.AssemblyLinearVelocity = Vector3.new(
            lock.X * (stickiness * 6),
            hrp.AssemblyLinearVelocity.Y,
            lock.Z * (stickiness * 6)
        )
    end
end)

--------------------------------------------------------
-- TR — LOCAL HITBOX RESIZER
--------------------------------------------------------

-- Returns every BasePart under Workspace.Games.[any].Replicated.Hitboxes
-- that belongs to the LocalPlayer (matched by UserId, Name, or parent folder name).
local function getMyHitboxParts()
    local found = {}
    local gamesFolder = Workspace:FindFirstChild("Games")
    if not gamesFolder then return found end

    local myName   = LocalPlayer.Name
    local myUserId = tostring(LocalPlayer.UserId)

    for _, gameInstance in ipairs(gamesFolder:GetChildren()) do
        local replicated = gameInstance:FindFirstChild("Replicated")
        if replicated then
            local hitboxesFolder = replicated:FindFirstChild("Hitboxes")
            if hitboxesFolder then
                -- Layout A: Hitboxes/<PlayerName or UserId>/<parts>
                for _, folder in ipairs(hitboxesFolder:GetChildren()) do
                    if folder.Name == myName or folder.Name == myUserId then
                        for _, part in ipairs(folder:GetDescendants()) do
                            if part:IsA("BasePart") then
                                table.insert(found, part)
                            end
                        end
                        -- also grab the folder itself if it IS a BasePart
                        if folder:IsA("BasePart") then
                            table.insert(found, folder)
                        end
                    end
                end
                -- Layout B: Hitboxes/<parts named after player>
                for _, part in ipairs(hitboxesFolder:GetChildren()) do
                    if part:IsA("BasePart") and
                       (part.Name == myName or part.Name == myUserId) then
                        table.insert(found, part)
                    end
                end
            end
        end
    end
    return found
end

local function applyTR()
    local parts = getMyHitboxParts()
    for _, part in ipairs(parts) do
        -- save original values once
        if not trOriginals[part] then
            trOriginals[part] = {
                Size         = part.Size,
                Transparency = part.Transparency,
            }
        end
        part.Size         = Vector3.new(trSize, trSize, trSize)
        part.Transparency = trTransparency
    end
end

local function resetTR()
    for part, orig in pairs(trOriginals) do
        if part and part.Parent then
            part.Size         = orig.Size
            part.Transparency = orig.Transparency
        end
    end
    trOriginals = {}
end

-- Heartbeat loop — runs every frame to fight any server-side resets
RunService.Heartbeat:Connect(function()
    if trEnabled then
        applyTR()
    end
end)

-- Re-scan originals after respawn
LocalPlayer.CharacterAdded:Connect(function()
    trOriginals = {}
    if trEnabled then
        task.wait(1.5)  -- wait for hitboxes to be parented in
        applyTR()
    end
end)


