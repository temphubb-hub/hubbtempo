-- FOOTBALL DETECTION
--------------------------------------------------------
local function getFootball()
    local gamesFolder = Workspace:FindFirstChild("Games")
    if gamesFolder then
        for _, gameInstance in ipairs(gamesFolder:GetChildren()) do
            local replicated = gameInstance:FindFirstChild("Replicated")
            if replicated then
                for _, item in ipairs(replicated:GetDescendants()) do
                    if item:IsA("BasePart") and item.Name == "Football" then return item end
                end
            end
        end
    end
    local miniGames = Workspace:FindFirstChild("MiniGames")
    if miniGames then
        for _, gameInstance in ipairs(miniGames:GetChildren()) do
            local replicated = gameInstance:FindFirstChild("Replicated")
            if replicated then
                for _, item in ipairs(replicated:GetDescendants()) do
                    if item:IsA("BasePart") and item.Name == "Football" then return item end
                end
            end
        end
    end
    local parkMap = Workspace:FindFirstChild("ParkMap")
    if parkMap then
        local replicated = parkMap:FindFirstChild("Replicated")
        if replicated then
            local fields = replicated:FindFirstChild("Fields")
            if fields then
                for _, field in ipairs(fields:GetChildren()) do
                    local fieldRep = field:FindFirstChild("Replicated")
                    if fieldRep then
                        local football = fieldRep:FindFirstChild("Football")
                        if football and football:IsA("BasePart") then return football end
                    end
                end
            end
        end
    end
    local parkMatch = Workspace:FindFirstChild("ParkMatchMap")
    if parkMatch then
        local replicated = parkMatch:FindFirstChild("Replicated")
        if replicated then
            local fields = replicated:FindFirstChild("Fields")
            if fields then
                local matchField = fields:FindFirstChild("MatchField")
                if matchField then
                    local mfRep = matchField:FindFirstChild("Replicated")
                    if mfRep then
                        local football = mfRep:FindFirstChild("Football")
                        if football and football:IsA("BasePart") then return football end
                    end
                end
            end
        end
    end
    return nil
end

--------------------------------------------------------
-- SMOOTH PULL
--------------------------------------------------------
local function smoothTeleportToBall()
    local ball = getFootball()
    if not ball or not hrp then return end
    local ballVelocity = ball.Velocity
    local ballSpeed = ballVelocity.Magnitude
    local offset = (ballSpeed > 0) and (ballVelocity.Unit * offsetDistance) or Vector3.new(0, 0, 0)
    local targetPosition = ball.Position + offset + Vector3.new(0, 3, 0)
    local distance = (targetPosition - hrp.Position).Magnitude
    if distance > maxPullDistance then return end
    local lookDirection = (ball.Position - hrp.Position).Unit
    hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(targetPosition, targetPosition + lookDirection), magnetSmoothness)
end

