local function ApplyHitbox(player)
    if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local playerHrp = player.Character.HumanoidRootPart
        if hitboxEnabled then
            playerHrp.Size = Vector3.new(hitboxScale, hitboxScale, hitboxScale)
            playerHrp.Transparency = transparencyValue
            playerHrp.BrickColor = BrickColor.new("Really red")
            playerHrp.Material = Enum.Material.Neon
            playerHrp.CanCollide = true
        else
            playerHrp.Size = Vector3.new(2, 2, 1)
            playerHrp.Transparency = 1
            playerHrp.Material = Enum.Material.Plastic
            playerHrp.CanCollide = false
        end
    end
end

local function UpdateHitboxes()
    for _, player in pairs(Players:GetPlayers()) do
        ApplyHitbox(player)
    end
end

Players.PlayerAdded:Connect(function(player)
